{
  "name": "clawpoint",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "serve": "node server.mjs",
    "test": "node --test test/*.test.mjs && vitest run --environment jsdom test/*.test.tsx",
    "smoke": "node scripts/smoke-test.mjs",
    "release:prepare": "node scripts/prepare-release.mjs",
    "deploy:install-service": "bash ops/deploy/install-service.sh",
    "deploy:release": "bash ops/deploy/deploy-release.sh"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  }
}
